# Personal/machine-specific configurations
.gitconfig.local
*.local
*/.zshrc.secrets
.zshrc.secrets
ssh/config.local
**/config.local
brew/Brewfile.local
jetbrains/.settings.json
php/conf.d/*.local
php/extensions.list.backup*

# Claude Code - project-local settings (global configs are in claude/)
.claude/settings.local.json

# Git context-specific configurations (per-directory identities)
git/.gitconfig.*
!git/.gitconfig.*.template

# Secrets and credentials
*secret*
!*.secrets.template
*password*
*token*
# OIDC token *tooling* is tracked; cached tokens live in ~/.claude/oidc/ (outside the repo)
!claude/scripts/oidc-token.sh
!claude/agents/oidc-token.md
# secret-guard is the hook that BLOCKS secret reads — tracked tooling, not a secret
!claude/hooks/secret-guard.sh
!claude/hooks/secret-guard.test.sh
*.pem
*.key
.env
.env.*

# Game config backups (only keep latest configs, not backups)
games/**/backup-*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

# Backup files
*.bak
*.backup
*.orig

# Cache directories
*.cache/
.zsh_sessions/
.zcompdump*

# Logs
*.log

# Local testing/temporary files
tmp/
temp/
test-local/