vscode "catppuccin.catppuccin-vsc"      # Catppuccin theme
vscode "pixl-garden.bongocat"           # Bongo Cat status bar

# Code Intelligence
vscode "christian-kohler.path-intellisense"  # Autocompletes filenames in import paths
vscode "dbaeumer.vscode-eslint"              # ESLint linter integration
vscode "editorconfig.editorconfig"           # .editorconfig support
vscode "esbenp.prettier-vscode"              # Prettier code formatter
vscode "wix.vscode-import-cost"              # Inline JS/TS import size hints

# AI Assistants
vscode "coderabbit.coderabbit-vscode"   # CodeRabbit AI code reviews
vscode "google.geminicodeassist"        # Gemini Code Assist
vscode "sst-dev.opencode"               # OpenCode AI coding agent

# Language Support
vscode "golang.go"                              # Go language support
vscode "ms-vscode.vscode-typescript-next"       # Latest TypeScript/JavaScript features
vscode "redhat.vscode-yaml"                     # YAML language support
