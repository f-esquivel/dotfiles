# =============================================================================
# Homebrew Bundle File
# =============================================================================
# Install all packages: brew bundle install --file=~/dotfiles/brew/Brewfile
# Update Brewfile:      brew bundle dump --file=~/dotfiles/brew/Brewfile --force
# Cleanup packages:     brew bundle cleanup --file=~/dotfiles/brew/Brewfile

# -----------------------------------------------------------------------------
# Taps (Third-party repositories)
# -----------------------------------------------------------------------------

tap "oven-sh/bun"

# -----------------------------------------------------------------------------
# CLI Tools & Utilities
# -----------------------------------------------------------------------------

brew "bat"              # Better cat with syntax highlighting
brew "curl"             # Transfer data with URLs
brew "fastfetch"        # System information tool
brew "fzf"              # Fuzzy finder
brew "gh"               # GitHub CLI
brew "git"              # Version control
brew "jq"               # JSON processor
brew "make"             # Build automation
brew "mkcert"           # SSL certificate generation
brew "nvm"              # Node version manager
brew "ripgrep"          # Fast grep alternative

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------

brew "act"              # Run GitHub Actions locally
brew "go"               # Go programming language

# -----------------------------------------------------------------------------
# Databases & Data Tools
# -----------------------------------------------------------------------------

brew "freetds"                                  # SQL Server protocol library
brew "libpq"                                    # PostgreSQL library
brew "pgvector"                                 # Vector similarity search for PostgreSQL
brew "postgresql@15", restart_service: :changed # PostgreSQL database
brew "redis", restart_service: :changed         # In-memory data store

# -----------------------------------------------------------------------------
# PHP & Composer
# -----------------------------------------------------------------------------

brew "imagemagick"                         # Image manipulation library (required for imagick PHP extension)
brew "php@8.2", restart_service: :changed, link: true
# Composer is installed via PHAR in install.sh (setup_composer) to avoid
# pulling in unversioned `php` as a dependency, which conflicts with php@8.2.
brew "pkgconf"                             # Package compiler helper
brew "zlib"                                # Compression library

# -----------------------------------------------------------------------------
# Runtime Environments
# -----------------------------------------------------------------------------

brew "oven-sh/bun/bun"  # Fast JavaScript runtime
brew "yarn"             # JavaScript package manager

# -----------------------------------------------------------------------------
# GUI Applications (Casks)
# -----------------------------------------------------------------------------

# Development
cask "appcleaner"               # Thorough application uninstaller
cask "claude-code"              # Claude AI code editor
cask "ghostty"                  # Terminal emulator
cask "jetbrains-toolbox"        # JetBrains tools manager
cask "ngrok"                    # Secure tunneling
cask "notion"                   # All-in-one workspace
cask "orbstack"                 # Docker & Linux container manager
cask "postman"                  # API development platform
cask "visual-studio-code"       # Code editor

# Cloud & DevOps
cask "gcloud-cli"               # Google Cloud CLI

# Utilities
cask "raycast"                  # Spotlight replacement & productivity tool
cask "the-unarchiver"           # Archive extraction

# Fonts
cask "font-fira-code"           # Monospaced font with ligatures
cask "font-iosevka"             # Slender monospaced font
cask "font-jetbrains-mono"      # JetBrains monospaced font

