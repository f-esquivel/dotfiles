{
  "cleanupPeriodDays": 30,
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(git push:*)"
    ],
    "ask": [
      "Bash(git commit:*)"
    ],
    "allow": [
      "Bash(~/.claude/scripts/oidc-token.sh:*)",
      "Bash(~/.claude/scripts/db-agent.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-commit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/oidc-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/db-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/oidc-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": false,
  "gitAttribution": false,
  "_notes": {
    "env.ENABLE_TOOL_SEARCH": "force deferred MCP tool loading; auto mode unreliable",
    "autoMemoryEnabled": "disable auto MEMORY.md writes; CLAUDE.md still active",
    "skipDangerousModePermissionPrompt": "suppress bypass-permissions launch warning"
  }
}
